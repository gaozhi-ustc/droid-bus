<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:DroidBus.App.Views"
        x:Class="DroidBus.App.MainWindow"
        Title="DroidBus 群控台"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#12161a">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBg" Color="#1e2229" />
        <SolidColorBrush x:Key="Accent"  Color="#4a90d9" />
        <SolidColorBrush x:Key="TextDim" Color="#8899aa" />
    </Window.Resources>

    <DockPanel>
        <!-- 顶部工具条 -->
        <Border DockPanel.Dock="Top" Height="44" Background="#2f3640" Padding="12,0">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="全部投屏" Classes="toolbar" Name="MirrorAllBtn" Click="OnMirrorAll" />
                <Button Content="刷新设备" Classes="toolbar" Name="RefreshBtn" Click="OnRefreshClick" />
                <Button Content="修复 ADB"  Classes="toolbar" Name="RecoverBtn" Click="OnRecoverAdb" />
                <Separator Width="1" Height="24" Background="#444" Margin="8,0" />
                <TextBlock Text="DroidBus" Foreground="#4a90d9" FontWeight="Bold" VerticalAlignment="Center" FontSize="14" />
                <TextBlock Name="StatusText" Text="就绪" Foreground="{StaticResource TextDim}" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- 右侧控制栏(占位) -->
        <Border DockPanel.Dock="Right" Width="240" Background="{StaticResource PanelBg}" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="控制栏" Foreground="{StaticResource TextDim}" FontSize="13" FontWeight="Bold" />
                <TextBlock Name="SelectedInfo" Text="未选中设备" Foreground="{StaticResource TextDim}" FontSize="11" TextWrapping="Wrap" />
                <Separator Background="#333" />
                <TextBlock Text="(控制功能端口自 WinForms)" Foreground="{StaticResource TextDim}" FontSize="10" />
            </StackPanel>
        </Border>

        <!-- 主区:3×2 画面墙网格 -->
        <Border Background="{StaticResource PanelBg}" Padding="8">
            <UniformGrid x:Name="TileGrid" Rows="2" Columns="3" />
        </Border>
    </DockPanel>

    <Window.Styles>
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#ccddee" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Button.toolbar:pointerover">
            <Setter Property="Background" Value="#3a4450" />
        </Style>
    </Window.Styles>
</Window>
